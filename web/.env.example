# ===== JEZAR Web - إعدادات البيئة =====
#
# الوضع التجريبي (Demo): إذا تركت إعدادات Firebase فارغة، يعمل التطبيق ببيانات
# تجريبية محلية تلقائياً (تُحفظ في المتصفح) — مثالي للتجربة دون إعداد Firebase.
#
# للتفعيل الحقيقي: أنشئ مشروع Firebase وانسخ القيم من:
#   Firebase Console > Project Settings > General > Your apps > SDK setup
# ثم انسخ هذا الملف إلى .env.local واملأ القيم.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# اجبار الوضع التجريبي حتى لو كانت إعدادات Firebase موجودة (true/false)
VITE_DEMO_MODE=
